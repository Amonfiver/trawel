# ============================================
# Configuración de entorno para Trawel
# ============================================
# Copia este archivo a .env y rellena con tus valores reales
# NUNCA subas .env a git (ya está en .gitignore)
# ============================================

# --------------------------------------------
# Supabase Configuration
# --------------------------------------------
# Obtén estos valores de tu proyecto Supabase:
# Project Settings > API > Project URL y anon public key
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --------------------------------------------
# Travel Data Source
# --------------------------------------------
# Opciones: mock | supabase
# 
# mock    = Usa datos locales estáticos (actual)
#           No requiere conexión a Supabase
#           Útil para desarrollo offline
#
# supabase = Usa base de datos Supabase (futuro)
#            Requiere VITE_SUPABASE_URL y VITE_SUPABASE_ANON_KEY
#            Se activará cuando implementemos SupabaseTravelDataSource
#
VITE_TRAVEL_DATA_SOURCE=mock

# ============================================
# NOTAS IMPORTANTES
# ============================================
# 1. Las variables con prefijo VITE_ son expuestas al frontend
# 2. La ANON KEY es pública y segura para usar en cliente
# 3. NO uses la SERVICE ROLE KEY aquí (es solo para backend)
# 4. Mantén mock hasta que conectemos Supabase oficialmente
# ============================================